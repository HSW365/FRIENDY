function openPricing() { document.getElementById('pricing-overlay').classList.add('open'); }
function closePricing() { document.getElementById('pricing-overlay').classList.remove('open'); }
function closePricingOutside(e) { if(e.target===document.getElementById('pricing-overlay')) closePricing(); }

const STRIPE_LINKS = {
  basic:   'https://buy.stripe.com/fZu7sLb9tgZ0g2W9ZV3VC04',
  plus:    'https://buy.stripe.com/fZu3cv4L5bEG4keb3Z3VC05',
  premium: 'https://buy.stripe.com/eVq14n6Td2461823Bx3VC06'
};

function choosePlan(plan,price,name) {
  APP.plan=plan; APP.planPrice=price; APP.planName=name;
  closePricing();
  window.location.href = STRIPE_LINKS[plan];
}

function updateNavBadge() {
  const b=document.getElementById('nav-badge');
  b.textContent=APP.planName;
  b.className='nav-badge show '+(APP.plan==='basic'?'nb-basic':APP.plan==='plus'?'nb-plus':'nb-prem');
}

function tryFriend(name) {
  const f=FRIENDS[name];
  if(!APP.plan || PH[APP.plan]<PH[f.planRequired]) { openPricing(); return; }
  openChat(name);
}

function openChat(name) {
  const f=FRIENDS[name];
  APP.friend={...f,name}; APP.history=[];
  document.getElementById('chat-av').textContent=f.initials;
  document.getElementById('chat-av').className='chat-av '+f.bgClass.replace('av-','').split('')[0];
  // set bg color via plan
  const avEl=document.getElementById('chat-av');
  if(f.planRequired==='basic') avEl.style.background='linear-gradient(135deg,rgba(124,106,247,0.3),rgba(124,106,247,0.1))';
  else if(f.planRequired==='plus') avEl.style.background='linear-gradient(135deg,rgba(212,95,138,0.3),rgba(212,95,138,0.1))';
  else avEl.style.background='linear-gradient(135deg,rgba(201,168,76,0.3),rgba(201,168,76,0.1))';
  document.getElementById('chat-fn').textContent=name;
  const tav=document.getElementById('typing-av');
  tav.textContent=f.initials;
  tav.style.background=avEl.style.background;
  const chip=document.getElementById('chat-chip');
  chip.textContent=APP.planName;
  chip.style.background=APP.plan==='premium'?'rgba(201,168,76,0.1)':APP.plan==='plus'?'rgba(212,95,138,0.1)':'rgba(124,106,247,0.1)';
  chip.style.color=APP.plan==='premium'?'var(--gold)':APP.plan==='plus'?'#e07aa0':'var(--accent2)';
  chip.style.borderColor=APP.plan==='premium'?'rgba(201,168,76,0.2)':APP.plan==='plus'?'rgba(212,95,138,0.2)':'rgba(124,106,247,0.2)';
  document.getElementById('messages').innerHTML='';
  document.getElementById('quick-prompts').style.display='flex';
  document.getElementById('landing').style.display='none';
  document.getElementById('chat-page').classList.add('active');
  const div=document.createElement('div'); div.className='date-div'; div.textContent='Today';
  document.getElementById('messages').appendChild(div);
  const greetings={
    Maya:`Hey — really glad you're here. This is your space. No filter, no judgment. What's going on?`,
    Dre:`Yo. What's good? Real talk — whatever you're dealing with, I'm here for it. What's on your mind?`,
    Sage:`Hey. Take a moment to settle in — there's no rush here. What's been on your mind lately?`,
    Kai:`Let's go — you showed up and that already says a lot. What's happening in your world right now?`,
    Nova:`Hey, I'm really glad you reached out. This is a space where we can go deep and actually figure things out. What's been going on for you?`
  };
  setTimeout(()=>addAI(greetings[name]),700);
}

function goBack() {
  document.getElementById('chat-page').classList.remove('active');
  document.getElementById('landing').style.display='flex';
  APP.friend=null; APP.history=[];
}

function addAI(text) {
  const f=APP.friend;
  const time=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  const row=document.createElement('div'); row.className='msg-row';
  const avEl=document.getElementById('chat-av');
  row.innerHTML=`
    <div class="msg-av" style="background:${avEl.style.background};font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.5);">${f.initials}</div>
    <div class="msg-col">
      <div class="bubble ai">${text}</div>
      <div class="msg-time">${time}</div>
    </div>`;
  document.getElementById('messages').appendChild(row);
  scrollBot();
}

function addUser(text) {
  const time=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  const row=document.createElement('div'); row.className='msg-row user';
  row.innerHTML=`
    <div class="msg-col">
      <div class="bubble user">${text}</div>
      <div class="msg-time">${time}</div>
    </div>
    <div class="msg-av user-av">You</div>`;
  document.getElementById('messages').appendChild(row);
  scrollBot();
}

function scrollBot() { const m=document.getElementById('messages'); setTimeout(()=>m.scrollTop=m.scrollHeight,50); }

async function sendMessage() {
  const input=document.getElementById('msg-input');
  const text=input.value.trim();
  if(!text||APP.isTyping) return;
  document.getElementById('quick-prompts').style.display='none';
  input.value=''; input.style.height='auto';
  addUser(text);
  APP.history.push({role:'user',content:text});
  APP.isTyping=true;
  document.getElementById('send-btn').disabled=true;
  document.getElementById('typing').classList.add('visible');
  scrollBot();
  try {
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:1000, system:APP.friend.persona, messages:APP.history })
    });
    const data=await res.json();
    const reply=data.content?.[0]?.text||'Still right here with you.';
    APP.history.push({role:'assistant',content:reply});
    const delay=Math.min(900+reply.length*14,3200);
    setTimeout(()=>{ document.getElementById('typing').classList.remove('visible'); addAI(reply); APP.isTyping=false; document.getElementById('send-btn').disabled=false; },delay);
  } catch(e) {
    setTimeout(()=>{ document.getElementById('typing').classList.remove('visible'); addAI("Connection hiccupped — but I didn't. What were you saying?"); APP.isTyping=false; document.getElementById('send-btn').disabled=false; },1000);
  }
}

function sendQuick(el) { document.getElementById('msg-input').value=el.textContent; sendMessage(); }

document.getElementById('msg-input').addEventListener('input',function(){ this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,120)+'px'; });
document.getElementById('msg-input').addEventListener('keydown',function(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();} });
</script>
</body>
