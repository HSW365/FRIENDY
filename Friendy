<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Friendy</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Satoshi:wght@300;400;500;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,300;0,700;0,900;1,300;1,700;1,900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080809;
  --s1: #0f0f11;
  --s2: #141417;
  --s3: #1c1c21;
  --s4: #242429;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.1);
  --text: #e8e6f0;
  --muted: #5a5a6e;
  --fog: #333340;
  --accent: #7c6af7;
  --accent2: #9d8fff;
  --accentGlow: rgba(124,106,247,0.2);
  --pink: #d45f8a;
  --pinkGlow: rgba(212,95,138,0.15);
  --gold: #c9a84c;
  --goldGlow: rgba(201,168,76,0.15);
  --green: #3dba7b;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Plus Jakarta Sans', sans-serif;
  overflow-x: hidden;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* GRAIN */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 600 600' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.035; pointer-events: none; z-index: 9998;
}

@keyframes rise { from{opacity:0;transform:translateY(28px);} to{opacity:1;transform:translateY(0);} }
@keyframes fadeIn { from{opacity:0;} to{opacity:1;} }
@keyframes popIn { from{opacity:0;transform:scale(0.94) translateY(10px);} to{opacity:1;transform:scale(1) translateY(0);} }
@keyframes pulse { 0%,100%{opacity:.3;} 50%{opacity:.8;} }
@keyframes bounce { 0%,80%,100%{transform:translateY(0);opacity:.3;} 40%{transform:translateY(-8px);opacity:1;} }
@keyframes modalIn { from{opacity:0;transform:translateY(24px) scale(0.96);} to{opacity:1;transform:translateY(0) scale(1);} }
@keyframes overlayIn { from{opacity:0;} to{opacity:1;} }
@keyframes spin { from{transform:rotate(0deg);} to{transform:rotate(360deg);} }
@keyframes lineGrow { from{transform:scaleX(0);} to{transform:scaleX(1);} }
@keyframes glowPulse { 0%,100%{opacity:0.4;} 50%{opacity:0.9;} }
@keyframes successPop { 0%{transform:scale(0) rotate(-10deg);} 60%{transform:scale(1.15) rotate(3deg);} 100%{transform:scale(1) rotate(0deg);} }

/* ===== LANDING ===== */
#landing { min-height:100vh; display:flex; flex-direction:column; position:relative; overflow:hidden; }

/* AMBIENT LIGHT */
.ambient {
  position: absolute; pointer-events: none; z-index: 0; border-radius: 50%; filter: blur(100px);
}
.amb1 { width:700px;height:700px;background:radial-gradient(circle,rgba(124,106,247,0.1) 0%,transparent 70%);top:-200px;right:-200px; }
.amb2 { width:500px;height:500px;background:radial-gradient(circle,rgba(212,95,138,0.06) 0%,transparent 70%);bottom:-100px;left:-150px; }

/* NAV */
nav {
  padding: 28px 48px;
  display: flex; justify-content: space-between; align-items: center;
  position: relative; z-index: 10;
  border-bottom: 1px solid var(--border);
  animation: rise 0.6s both;
}

.wordmark {
  font-family: 'Fraunces', serif;
  font-size: 22px; font-weight: 900;
  color: var(--text); letter-spacing: -0.03em;
}
.wordmark span { color: var(--accent); font-style: italic; }

.nav-right { display:flex; gap:14px; align-items:center; }

.nav-badge {
  font-size: 11px; font-weight: 700; padding: 7px 16px;
  border-radius: 6px; letter-spacing: 0.08em; text-transform: uppercase;
  display: none; border: 1px solid;
}
.nav-badge.show { display:block; }
.nb-basic { background: rgba(124,106,247,0.08); color: var(--accent2); border-color: rgba(124,106,247,0.2); }
.nb-plus  { background: rgba(212,95,138,0.08); color: #e07aa0; border-color: rgba(212,95,138,0.2); }
.nb-prem  { background: rgba(201,168,76,0.08); color: var(--gold); border-color: rgba(201,168,76,0.2); }

/* HERO */
.hero {
  flex: 1; display: flex; flex-direction: column;
  justify-content: center; align-items: flex-start;
  padding: 80px 48px 80px;
  position: relative; z-index: 2; max-width: 1100px;
}

.hero-kicker {
  font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 32px; display: flex; align-items: center; gap: 12px;
  animation: rise 0.8s 0.2s both;
}
.hero-kicker::before {
  content: ''; width: 32px; height: 1px;
  background: var(--accent); display: block;
}

.hero-h1 {
  font-family: 'Fraunces', serif;
  font-size: clamp(52px, 7vw, 96px);
  font-weight: 900; line-height: 0.95;
  letter-spacing: -0.04em; color: var(--text);
  max-width: 780px; animation: rise 0.8s 0.35s both;
}
.hero-h1 em { font-style: italic; color: var(--accent2); }
.hero-h1 .lined {
  position: relative; display: inline-block;
}
.hero-h1 .lined::after {
  content: ''; position: absolute;
  bottom: 4px; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--pink));
  transform-origin: left; animation: lineGrow 1s 1.2s both;
}

.hero-sub {
  margin-top: 28px; font-size: 17px; line-height: 1.75;
  color: var(--muted); max-width: 520px; font-weight: 400;
  animation: rise 0.8s 0.5s both;
}

.hero-actions {
  display: flex; gap: 14px; margin-top: 48px; align-items: center;
  animation: rise 0.8s 0.65s both;
}

.btn-primary {
  background: var(--accent);
  color: white; padding: 16px 36px;
  border-radius: 8px; font-size: 15px; font-weight: 700;
  border: none; cursor: pointer;
  font-family: 'Plus Jakarta Sans', sans-serif;
  letter-spacing: -0.01em;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 8px 32px rgba(124,106,247,0.35);
}
.btn-primary:hover { background: var(--accent2); transform: translateY(-2px); box-shadow: 0 16px 48px rgba(124,106,247,0.45); }

.btn-ghost {
  color: var(--muted); font-size: 14px; font-weight: 600;
  background: transparent; border: 1px solid var(--border2);
  padding: 16px 28px; border-radius: 8px; cursor: pointer;
  font-family: 'Plus Jakarta Sans', sans-serif;
  transition: color 0.2s, border-color 0.2s;
}
.btn-ghost:hover { color: var(--text); border-color: var(--border2); }

.hero-stats {
  display: flex; gap: 48px; margin-top: 80px;
  padding-top: 48px; border-top: 1px solid var(--border);
  animation: rise 0.8s 0.8s both; flex-wrap: wrap;
}
.stat-num {
  font-family: 'Fraunces', serif;
  font-size: 36px; font-weight: 900;
  color: var(--text); letter-spacing: -0.03em;
}
.stat-label { font-size: 12px; color: var(--muted); margin-top: 4px; letter-spacing: 0.04em; }

/* FRIENDS GRID */
.friends-section {
  padding: 100px 48px; position: relative; z-index: 2;
  border-top: 1px solid var(--border);
}
.sec-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:48px; }
.sec-title {
  font-family: 'Fraunces', serif;
  font-size: clamp(28px, 4vw, 44px); font-weight: 900;
  letter-spacing: -0.03em; color: var(--text); line-height: 1.1;
}
.sec-title em { font-style: italic; color: var(--accent2); }
.sec-sub { font-size: 13px; color: var(--muted); font-weight: 400; max-width: 300px; text-align: right; line-height: 1.6; }

.friends-grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}

.friend-card {
  background: var(--s1); border: 1px solid var(--border);
  border-radius: 16px; padding: 28px 22px;
  cursor: pointer; transition: all 0.25s; position: relative;
  overflow: hidden;
}
.friend-card::before {
  content: ''; position: absolute; inset: 0;
  opacity: 0; transition: opacity 0.3s;
}
.friend-card:hover { border-color: rgba(124,106,247,0.3); transform: translateY(-4px); }
.friend-card:hover::before { opacity: 1; }

.fc-basic::before { background: linear-gradient(135deg, rgba(124,106,247,0.06) 0%, transparent 60%); }
.fc-plus::before  { background: linear-gradient(135deg, rgba(212,95,138,0.06) 0%, transparent 60%); }
.fc-prem::before  { background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, transparent 60%); }

.friend-card:hover.fc-basic { border-color: rgba(124,106,247,0.35); box-shadow: 0 16px 48px rgba(124,106,247,0.12); }
.friend-card:hover.fc-plus  { border-color: rgba(212,95,138,0.35); box-shadow: 0 16px 48px rgba(212,95,138,0.1); }
.friend-card:hover.fc-prem  { border-color: rgba(201,168,76,0.3); box-shadow: 0 16px 48px rgba(201,168,76,0.08); }

.fc-plan-tag {
  font-size: 10px; font-weight: 700; padding: 3px 9px;
  border-radius: 4px; letter-spacing: 0.1em; text-transform: uppercase;
  margin-bottom: 20px; display: inline-block; border: 1px solid;
}
.tag-basic { background: rgba(124,106,247,0.1); color: var(--accent2); border-color: rgba(124,106,247,0.2); }
.tag-plus  { background: rgba(212,95,138,0.1); color: #e07aa0; border-color: rgba(212,95,138,0.2); }
.tag-prem  { background: rgba(201,168,76,0.1); color: var(--gold); border-color: rgba(201,168,76,0.2); }

.fc-avatar {
  width: 48px; height: 48px; border-radius: 12px;
  margin-bottom: 16px; display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; letter-spacing: 0.06em;
  text-transform: uppercase; color: rgba(255,255,255,0.5);
}
.av-basic { background: linear-gradient(135deg, rgba(124,106,247,0.3), rgba(124,106,247,0.1)); }
.av-plus  { background: linear-gradient(135deg, rgba(212,95,138,0.3), rgba(212,95,138,0.1)); }
.av-prem  { background: linear-gradient(135deg, rgba(201,168,76,0.3), rgba(201,168,76,0.1)); }

.fc-name {
  font-family: 'Fraunces', serif;
  font-size: 18px; font-weight: 700; color: var(--text);
  letter-spacing: -0.02em; margin-bottom: 6px;
}
.fc-vibe { font-size: 12px; color: var(--muted); line-height: 1.55; }
.fc-price {
  font-family: 'Fraunces', serif;
  font-size: 22px; font-weight: 900; color: var(--text);
  margin-top: 20px; letter-spacing: -0.02em;
}
.fc-price span { font-size: 12px; color: var(--muted); font-weight: 400; font-family: 'Plus Jakarta Sans', sans-serif; }

/* WHY SECTION */
.why-section { padding: 0 48px 100px; position: relative; z-index: 2; }
.why-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
.why-card { background: var(--s1); padding: 36px 32px; }
.why-num { font-family: 'Fraunces', serif; font-size: 48px; font-weight: 900; color: var(--fog); letter-spacing: -0.04em; margin-bottom: 16px; }
.why-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 10px; letter-spacing: -0.01em; }
.why-desc { font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ===== MODALS ===== */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(4,4,5,0.92); backdrop-filter: blur(16px);
  z-index: 1000; align-items: center; justify-content: center; padding: 20px;
}
.modal-overlay.open { display: flex; animation: overlayIn 0.3s both; }

.modal-box {
  background: var(--s1); border: 1px solid var(--border2);
  border-radius: 20px; width: 100%; max-height: 92vh;
  overflow-y: auto; box-shadow: 0 40px 120px rgba(0,0,0,0.8);
  animation: modalIn 0.4s both; position: relative;
}
.modal-box::-webkit-scrollbar { width: 3px; }
.modal-box::-webkit-scrollbar-thumb { background: var(--fog); border-radius: 2px; }
.pricing-box { max-width: 900px; }
.payment-box { max-width: 460px; }

.modal-close {
  position: absolute; top: 20px; right: 20px;
  width: 34px; height: 34px; border-radius: 8px;
  border: 1px solid var(--border); background: var(--s2);
  cursor: pointer; font-size: 16px; color: var(--muted);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; z-index: 2;
}
.modal-close:hover { background: var(--s3); color: var(--text); }

/* PRICING */
.modal-top { padding: 44px 44px 32px; border-bottom: 1px solid var(--border); }
.modal-top h2 { font-family:'Fraunces',serif; font-size:34px; font-weight:900; color:var(--text); letter-spacing:-0.03em; margin-bottom:8px; }
.modal-top h2 em { font-style:italic; color:var(--accent2); }
.modal-top p { font-size:14px; color:var(--muted); }

.plans-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; padding:32px 44px 44px; }

.plan-card {
  border: 1px solid var(--border); border-radius: 16px;
  padding: 28px 24px; background: var(--s2);
  display: flex; flex-direction: column; position: relative;
  cursor: pointer; transition: all 0.2s;
}
.plan-card:hover { transform: translateY(-2px); }
.plan-card.pop { border-color: rgba(124,106,247,0.3); background: var(--s2); box-shadow: 0 0 0 1px rgba(124,106,247,0.15) inset; }
.plan-card.prem { border-color: rgba(201,168,76,0.25); }

.plan-hot {
  position: absolute; top: -12px; left: 24px;
  background: var(--accent); color: white;
  font-size: 10px; font-weight: 800; padding: 3px 14px;
  border-radius: 4px; letter-spacing: 0.1em; text-transform: uppercase;
}

.plan-label { font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 20px; display: block; }
.plan-price { font-family:'Fraunces',serif; font-size:56px; font-weight:900; line-height:1; letter-spacing:-0.04em; color:var(--text); }
.plan-card.pop .plan-price { color: var(--accent2); }
.plan-card.prem .plan-price { color: var(--gold); }
.plan-mo { font-size:12px; color:var(--muted); margin:4px 0 8px; }
.plan-name { font-family:'Fraunces',serif; font-size:20px; font-weight:700; color:var(--text); letter-spacing:-0.02em; margin-bottom:4px; }
.plan-tagline { font-size:12px; color:var(--muted); margin-bottom:20px; line-height:1.5; }

.plan-divider { height:1px; background:var(--border); margin-bottom:20px; }

.plan-features { list-style:none; display:flex; flex-direction:column; gap:9px; margin-bottom:24px; flex:1; }
.plan-features li { font-size:12px; color:var(--muted); display:flex; align-items:flex-start; gap:8px; line-height:1.5; }
.plan-features li::before { content:'—'; font-size:11px; flex-shrink:0; margin-top:1px; font-weight:700; }
.plan-card.pop .plan-features li::before { color: var(--accent2); }
.plan-card.prem .plan-features li::before { color: var(--gold); }
.plan-card:not(.pop):not(.prem) .plan-features li::before { color: var(--green); }

.plan-btn {
  width: 100%; padding: 14px;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; font-weight: 700;
  border-radius: 8px; cursor: pointer; transition: all 0.2s; letter-spacing: -0.01em;
  border: 1px solid var(--border2); background: transparent; color: var(--text);
}
.plan-btn:hover { background: var(--s3); }
.plan-card.pop .plan-btn { background: var(--accent); color: white; border-color: transparent; box-shadow: 0 8px 24px rgba(124,106,247,0.3); }
.plan-card.pop .plan-btn:hover { background: var(--accent2); }
.plan-card.prem .plan-btn { background: var(--gold); color: #0a0800; border-color: transparent; font-weight: 800; }
.plan-card.prem .plan-btn:hover { filter: brightness(1.08); }

/* PAYMENT */
.pay-header { padding: 36px 36px 24px; border-bottom: 1px solid var(--border); }
.pay-header h3 { font-family:'Fraunces',serif; font-size:24px; font-weight:900; color:var(--text); letter-spacing:-0.02em; margin-bottom:4px; }
.pay-header p { font-size:13px; color:var(--muted); }
.pay-plan-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:6px; font-size:11px; font-weight:700; margin-top:14px; letter-spacing:0.06em; text-transform:uppercase; border:1px solid; }

.pay-body { padding: 28px 36px 36px; }
.pay-label { font-size:10px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--muted); margin-bottom:12px; display:block; }

.pay-methods { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:24px; }
.pay-method {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 14px 16px;
  cursor: pointer; display: flex; align-items: center; gap: 10px; transition: all 0.2s;
}
.pay-method:hover { border-color: var(--border2); background: var(--s3); }
.pay-method.selected { border-color: rgba(124,106,247,0.4); background: rgba(124,106,247,0.05); }
.pm-icon { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 14px; font-weight: 800; }
.pm-name { font-size: 13px; font-weight: 700; color: var(--text); }
.pm-sub { font-size: 11px; color: var(--muted); }
.pm-check { width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid var(--fog); margin-left: auto; flex-shrink: 0; transition: all 0.2s; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 800; color: white; }
.pay-method.selected .pm-check { background: var(--accent); border-color: var(--accent); }
.pay-method.selected .pm-check::after { content: '✓'; }

/* CARD FORM */
.card-form { display: none; margin-bottom: 20px; }
.card-form.show { display: block; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
.form-field label { font-size: 10px; font-weight: 700; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
.form-field input {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 8px; padding: 12px 14px;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; color: var(--text);
  outline: none; transition: border-color 0.2s;
}
.form-field input::placeholder { color: var(--muted); }
.form-field input:focus { border-color: rgba(124,106,247,0.4); }

/* EXT PAY */
.ext-info { display: none; background: var(--s2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
.ext-info.show { display: block; }
.ext-label { font-size: 11px; font-weight: 600; color: var(--muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.1em; }
.ext-handle { font-size: 18px; font-weight: 800; color: var(--text); font-family: 'Fraunces', serif; letter-spacing: -0.01em; margin-bottom: 8px; }
.ext-handle em { font-style: normal; color: var(--accent2); }
.ext-note { font-size: 12px; color: var(--muted); line-height: 1.65; }
.ext-amount-tag { display: inline-block; background: rgba(124,106,247,0.1); color: var(--accent2); font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 6px; margin-top: 10px; border: 1px solid rgba(124,106,247,0.2); }

.pay-btn {
  width: 100%; padding: 16px;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px; font-weight: 800;
  border: none; border-radius: 10px; cursor: pointer;
  background: var(--accent); color: white;
  transition: transform 0.15s, box-shadow 0.15s, background 0.2s;
  box-shadow: 0 8px 32px rgba(124,106,247,0.3);
  letter-spacing: -0.01em;
}
.pay-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 48px rgba(124,106,247,0.4); background: var(--accent2); }
.pay-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.pay-secure { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 12px; font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }

/* SUCCESS */
.success-screen { display: none; text-align: center; padding: 56px 40px; }
.success-screen.show { display: block; animation: popIn 0.5s both; }
.success-icon { width: 72px; height: 72px; border-radius: 20px; background: rgba(61,186,123,0.12); border: 1px solid rgba(61,186,123,0.25); margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; animation: successPop 0.6s 0.1s both; }
.success-icon svg { width: 32px; height: 32px; stroke: var(--green); fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
.success-screen h3 { font-family:'Fraunces',serif; font-size:28px; font-weight:900; color:var(--text); letter-spacing:-0.02em; margin-bottom:10px; }
.success-screen p { font-size:14px; color:var(--muted); line-height:1.65; max-width:300px; margin:0 auto 28px; }
.success-btn { background: var(--accent); color: white; padding: 14px 40px; border-radius: 8px; font-size: 15px; font-weight: 700; border: none; cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif; transition: background 0.2s; }
.success-btn:hover { background: var(--accent2); }

/* ===== CHAT ===== */
#chat-page { display: none; height: 100vh; flex-direction: column; background: var(--bg); }
#chat-page.active { display: flex; }

.chat-header {
  padding: 16px 24px;
  background: var(--s1); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 14px; flex-shrink: 0;
}
.back-btn {
  width: 34px; height: 34px; border-radius: 8px;
  border: 1px solid var(--border); background: transparent;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-size: 14px; color: var(--muted); transition: all 0.2s; flex-shrink: 0;
}
.back-btn:hover { background: var(--s2); color: var(--text); }

.chat-av {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: rgba(255,255,255,0.5);
  text-transform: uppercase; letter-spacing: 0.06em; flex-shrink: 0;
}
.chat-fn { font-family:'Fraunces',serif; font-size:16px; font-weight:700; color:var(--text); letter-spacing:-0.01em; }
.chat-status { font-size: 11px; color: var(--green); font-weight: 500; margin-top: 1px; display: flex; align-items: center; gap: 5px; }
.chat-status::before { content: ''; width: 5px; height: 5px; background: var(--green); border-radius: 50%; display: inline-block; }
.chat-plan-chip { margin-left: auto; font-size: 10px; font-weight: 700; padding: 5px 12px; border-radius: 6px; letter-spacing: 0.08em; text-transform: uppercase; flex-shrink: 0; border: 1px solid; }

.messages { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth; }
.messages::-webkit-scrollbar { width: 3px; }
.messages::-webkit-scrollbar-thumb { background: var(--fog); border-radius: 2px; }

.msg-row { display: flex; gap: 10px; animation: popIn 0.3s ease both; }
.msg-row.user { flex-direction: row-reverse; }

.msg-av {
  width: 30px; height: 30px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 800; flex-shrink: 0; align-self: flex-end;
  text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.5);
}
.msg-av.user-av { background: var(--accent); color: white; font-size: 11px; }

.bubble { max-width: 72%; padding: 13px 17px; border-radius: 14px; font-size: 14px; line-height: 1.7; font-weight: 400; }
.bubble.ai { background: var(--s2); color: var(--text); border-radius: 14px 14px 14px 4px; border: 1px solid var(--border); }
.bubble.user { background: var(--accent); color: white; border-radius: 14px 14px 4px 14px; }

.msg-col { display: flex; flex-direction: column; }
.msg-time { font-size: 10px; color: var(--muted); margin-top: 5px; padding: 0 4px; letter-spacing: 0.04em; }
.msg-row.user .msg-time { text-align: right; }

.date-div { text-align: center; font-size: 10px; color: var(--muted); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin: 4px 0; display: flex; align-items: center; gap: 10px; }
.date-div::before, .date-div::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.typing-indicator { display: none; gap: 10px; align-items: center; padding: 0 4px; }
.typing-indicator.visible { display: flex; }
.typing-bubble { background: var(--s2); border: 1px solid var(--border); border-radius: 14px 14px 14px 4px; padding: 12px 16px; display: flex; gap: 5px; align-items: center; }
.dot { width: 6px; height: 6px; background: var(--muted); border-radius: 50%; animation: bounce 1.2s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

.chat-input-area { padding: 14px 20px 18px; background: var(--s1); border-top: 1px solid var(--border); flex-shrink: 0; }
.input-row { display: flex; gap: 10px; align-items: flex-end; background: var(--s2); border: 1px solid var(--border); border-radius: 14px; padding: 10px 10px 10px 16px; transition: border-color 0.2s; }
.input-row:focus-within { border-color: rgba(124,106,247,0.35); }
#msg-input { flex: 1; border: none; background: transparent; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; color: var(--text); resize: none; outline: none; line-height: 1.5; max-height: 120px; min-height: 22px; overflow-y: auto; }
#msg-input::placeholder { color: var(--muted); }

.send-btn { width: 34px; height: 34px; border-radius: 8px; background: var(--accent); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, transform 0.15s; flex-shrink: 0; }
.send-btn:hover { background: var(--accent2); transform: scale(1.05); }
.send-btn:active { transform: scale(0.95); }
.send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.send-icon { width: 14px; height: 14px; fill: none; stroke: white; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

.quick-prompts { display: flex; gap: 8px; padding: 10px 20px 0; flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; }
.quick-prompts::-webkit-scrollbar { display: none; }
.prompt-chip { background: var(--s2); border: 1px solid var(--border); color: var(--muted); font-size: 12px; font-weight: 500; padding: 7px 14px; border-radius: 8px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-family: 'Plus Jakarta Sans', sans-serif; }
.prompt-chip:hover { background: var(--s3); border-color: rgba(124,106,247,0.3); color: var(--text); }

.input-hint { text-align: center; font-size: 11px; color: var(--muted); margin-top: 10px; letter-spacing: 0.03em; }

@media(max-width:768px) {
